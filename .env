# ============================================
# AIOS — Configuration de l'environnement
# ============================================
# Z-AI (intégré) fonctionne SANS aucune clé API.
# Remplis les clés des providers que tu veux utiliser.
# ============================================

# ── Base de données ───────────────────────────
DATABASE_URL="file:./db/custom.db"

# ── Mistral AI ────────────────────────────────
# Obtient ta clé : https://console.mistral.ai/
MISTRAL_API_KEY=

# ── OpenAI (ChatGPT) ─────────────────────────
# Obtient ta clé : https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Anthropic (Claude) ────────────────────────
# Obtient ta clé : https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Google Gemini ─────────────────────────────
# Obtient ta clé : https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── xAI Grok ──────────────────────────────────
# Obtient ta clé : https://console.x.ai/
XAI_API_KEY=

# ── DeepSeek ──────────────────────────────────
# Obtient ta clé : https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ── IA Locale (Ollama) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Telegram Bot ──────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Application ───────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
